diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -255,9 +255,25 @@ endif()
 set(USE_Z3      ON CACHE STRING "Use Z3 SMT solver for TileLang optimizations")
 set(USE_PYPI_Z3 ON CACHE BOOL   "Use Z3 provided by PyPI z3-solver package")

-if(USE_Z3 AND USE_PYPI_Z3)
-  list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/cmake/pypi-z3")
-  find_package(Z3 REQUIRED)
+if(USE_Z3)
+  if(USE_PYPI_Z3)
+    # Use PyPI z3-solver package layout (bundled in site-packages/z3/{include,lib})
+    list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/cmake/pypi-z3")
+    find_package(Z3 REQUIRED)
+  else()
+    # Use conda-forge z3 package layout (headers in $PREFIX/include, lib in $PREFIX/lib)
+    find_path(Z3_INCLUDE_DIR NAMES z3++.h PATHS $ENV{PREFIX}/include $ENV{CONDA_PREFIX}/include)
+    find_library(Z3_LIBRARY NAMES z3 libz3 PATHS $ENV{PREFIX}/lib $ENV{CONDA_PREFIX}/lib)
+    if(Z3_INCLUDE_DIR AND Z3_LIBRARY)
+      message(STATUS "Found Z3 (conda): ${Z3_LIBRARY}")
+      message(STATUS "Z3 include dir: ${Z3_INCLUDE_DIR}")
+      add_library(z3::libz3 SHARED IMPORTED GLOBAL)
+      set_target_properties(z3::libz3 PROPERTIES IMPORTED_LOCATION ${Z3_LIBRARY} INTERFACE_INCLUDE_DIRECTORIES ${Z3_INCLUDE_DIR})
+      set(Z3_FOUND TRUE)
+    else()
+      message(FATAL_ERROR "Could not find Z3 library. Install z3 conda package or set USE_PYPI_Z3=ON.")
+    endif()
+  endif()
 endif()

 # Include tvm after configs have been populated
